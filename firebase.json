{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      "worktrees/**",
      "new_3D/**"
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "memory": "512MiB"
    }
  },
  "storage": {
    "rules": "storage.rules"
  }
}
