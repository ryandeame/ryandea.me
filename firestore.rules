rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function publicProfileOwner() {
      return signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(userId);

      match /locations/{locationId} {
        allow read: if signedIn();
        allow create, update, delete: if isOwner(userId);

        match /images/{imageId} {
          allow read: if signedIn();
          allow create, update, delete: if isOwner(userId);
        }

        match /meta/{metaId} {
          allow read: if signedIn();
          allow create, update, delete: if isOwner(userId);
        }
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /publicProfiles/{username} {
      allow read: if true;
      allow create: if publicProfileOwner();
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;

      match /topImages/{imageId} {
        allow read: if true;
        allow create, update: if signedIn()
          && get(/databases/$(database)/documents/publicProfiles/$(username)).data.uid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid;
        allow delete: if signedIn()
          && get(/databases/$(database)/documents/publicProfiles/$(username)).data.uid == request.auth.uid;
      }
    }

    match /appMetadata/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /locations/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
